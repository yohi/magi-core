# MAGI System API 設定
MAGI_API_KEY=

# WebUI 関連設定
# 注意: 以下の変数は MAGI_ プレフィックスを使用しません (Vite との互換性、または一般的な命名規則のため)

# 最大同時実行数
MAX_CONCURRENCY=10

# セッション有効期限 (秒)
SESSION_TTL_SEC=600

# CORS 許可オリジン (カンマ区切り、空の場合は制限なし)
CORS_ORIGINS=

# Vite クライアント用 API ベース URL (VITE_ プレフィックスが必要)
VITE_API_BASE=

# Vite クライアント用 WebSocket ベース URL (VITE_ プレフィックスが必要)
VITE_WS_BASE=
